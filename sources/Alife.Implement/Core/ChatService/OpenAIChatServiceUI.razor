@namespace Alife.Plugins.Official.Components
@inherits Alife.Framework.PluginUIBase
@using Alife.Basic
@using Alife.Framework
@using Newtonsoft.Json
@using Alife.Implement
@inject ConfigurationSystem ConfigurationSystem

<div style="background: #fff; padding: 20px; border-radius: 8px;">
    <Title Level="4" Style="margin-bottom: 24px;">OpenAI 对话服务配置</Title>
    <Form TModel="OpenAIChatServiceConfig" Model="@config" Layout="@FormLayout.Vertical">
    <FormItem Label="Endpoint">
        <Input @bind-Value="@config.endpoint" placeholder="例如: https://api.deepseek.com/v1" />
    </FormItem>
    <FormItem Label="Model ID">
        <Input @bind-Value="@config.modelId" placeholder="例如: deepseek-chat" />
    </FormItem>
    <FormItem Label="API Key">
        <InputPassword @bind-Value="@config.apiKey" />
    </FormItem>
    <FormItem>
        <Button id="btn-save-plugin-config" Type="@ButtonType.Primary" OnClick="Save">保存 OpenAI 配置</Button>
    </FormItem>
</Form>

@code {
    OpenAIChatServiceConfig config = new();

    protected override void OnInitialized()
    {
        var result = ConfigurationSystem.GetConfiguration(PluginType);
        if (result is OpenAIChatServiceConfig c)
        {
            config = (OpenAIChatServiceConfig)c.Clone();
        }
    }

    async Task Save()
    {
        ConfigurationSystem.SetConfiguration(PluginType, config);
    }
}
</div>
