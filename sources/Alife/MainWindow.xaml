<Window x:Class="Alife.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:alife="clr-namespace:Alife"
        Title="Alife AI Assistant" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="White"
        AllowsTransparency="False">

    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e5e5e5" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      GlassFrameThickness="0"
                      CornerRadius="12"
                      ResizeBorderThickness="8" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#f0f0f0" BorderThickness="1" Background="#ffffff" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 沉浸式标题栏 -->
            <Grid Grid.Row="0" Height="40" Background="#f8f9fa">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 标题与拖拽区 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="Alife" IsHitTestVisible="False" FontWeight="Bold" Foreground="#1890ff"
                               FontSize="14" />
                    <TextBlock Text=" - 创造赛博生命" IsHitTestVisible="False" Foreground="#666" FontSize="12"
                               Margin="4,0,0,0" VerticalAlignment="Bottom" />
                </StackPanel>

                <!-- 窗口控制按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowControlButtonStyle}" Content="─" Click="MinimizeClick" />
                    <Button Style="{StaticResource WindowControlButtonStyle}" Content="▢" Click="MaximizeClick"
                            Name="MaxBtn" />
                    <Button Style="{StaticResource WindowControlButtonStyle}" Content="✕" Click="CloseClick" />
                </StackPanel>
            </Grid>

            <!-- 内容区：Blazor 视图 -->
            <Border Grid.Row="1" CornerRadius="0,0,12,12" ClipToBounds="True">
                <blazor:BlazorWebView HostPage="wwwroot/index.html" Services="{x:Static alife:App.ServiceProvider}">
                    <blazor:BlazorWebView.RootComponents>
                        <blazor:RootComponent Selector="#app" ComponentType="{x:Type alife:Components.Routes}" />
                    </blazor:BlazorWebView.RootComponents>
                </blazor:BlazorWebView>
            </Border>
        </Grid>
    </Border>
</Window>