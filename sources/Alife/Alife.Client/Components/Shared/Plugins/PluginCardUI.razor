@using Alife.Components.Services
@using Alife.Components.Shared.Common
@using Alife.PluginMarket
@inject PluginMarketService PluginMarketService
@inject INotificationService NotificationService

<ErrorWindowUI @bind-Value="@operException" />

<div class="plugin-card" @onclick="HandleClick">
    <div class="plugin-card-header">
        <div class="plugin-icon-wrapper">
            <div class="plugin-icon">
                <Icon Type="@IconType.Outline.Appstore" Style="font-size: 16px; color: #1890ff;" />
            </div>
            @if (PluginMarketService.IsInstalled(Plugin.Id))
            {
                <div class="plugin-badge"></div>
            }
        </div>
        <div class="plugin-info">
            <div class="plugin-name">@Plugin.Name</div>
            @if (!string.IsNullOrEmpty(Plugin.Author))
            {
                <div class="plugin-author">@Plugin.Author</div>
            }
        </div>
        <div class="plugin-actions">
            @if (PluginMarketService.IsInstalled(Plugin.Id))
            {
                <span class="plugin-version">v@(PluginMarketService.GetInstalledVersion(Plugin.Id))</span>
                if (hasUpdate)
                {
                    <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small" Loading="isOperating"
                             OnClick="Upgrade" OnClickStopPropagation="true"
                             Style="background: #52c41a; border-color: #52c41a;">
                        升级
                    </Button>
                }
            }
            else
            {
                <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small" Loading="isOperating"
                         OnClick="@(() => Install($"插件 [{Plugin.Name}] 安装成功"))" OnClickStopPropagation="true">
                    安装
                </Button>
            }
        </div>
    </div>

    <div class="plugin-meta">
        <Tooltip Title="@(Plugin.Description)" Disabled="@(string.IsNullOrWhiteSpace(Plugin.Description))">
            <AntDesign.Text Type="@TextElementType.Secondary" Style="font-size: 11px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                @(string.IsNullOrWhiteSpace(Plugin.Description) ? Plugin.Id : Plugin.Description)
            </AntDesign.Text>
        </Tooltip>
    </div>
</div>

<style>
    .plugin-card {
        background: #fff;
        border: 1px solid #f0f0f0;
        border-radius: 6px;
        padding: 10px;
        cursor: pointer;
        transition: all 0.3s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .plugin-card:hover {
        border-color: #1890ff;
        box-shadow: 0 2px 8px rgba(24, 144, 255, 0.15);
        transform: translateY(-1px);
    }

    .plugin-card-header {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
        gap: 8px;
    }

    .plugin-icon-wrapper {
        position: relative;
        flex-shrink: 0;
    }

    .plugin-icon {
        width: 32px;
        height: 32px;
        background: #e6f7ff;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .plugin-badge {
        position: absolute;
        top: -3px;
        right: -3px;
        width: 12px;
        height: 12px;
        background: #52c41a;
        border-radius: 50%;
        border: 2px solid #fff;
    }

    .plugin-info {
        flex: 1;
        min-width: 0;
    }

    .plugin-name {
        font-size: 13px;
        font-weight: 600;
        color: rgba(0, 0, 0, 0.85);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .plugin-author {
        font-size: 11px;
        color: rgba(0, 0, 0, 0.45);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .plugin-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .plugin-version {
        font-size: 12px;
        color: rgba(0, 0, 0, 0.45);
    }

    .plugin-meta {
    }
</style>

@code {
    [Parameter] public Plugin Plugin { get; set; } = null!;
    [Parameter] public EventCallback<Plugin> OnClick { get; set; }
    [Parameter] public EventCallback OnInstalled { get; set; }

    bool isOperating;
    bool hasUpdate;
    Exception? operException;

    protected override void OnParametersSet()
    {
        hasUpdate = PluginMarketService.HasUpdate(Plugin);
    }

    async Task HandleClick()
    {
        await OnClick.InvokeAsync(Plugin);
    }

    async Task Install(string message)
    {
        string? version = PluginMarketService.GetLatestVersion(Plugin);
        if (version == null) return;
        isOperating = true;
        try
        {
            await PluginMarketService.InstallPlugin(Plugin, version);
            _ = NotificationService.Success(new NotificationConfig { Message = message });
            hasUpdate = PluginMarketService.HasUpdate(Plugin);
            await OnInstalled.InvokeAsync();
        }
        catch (Exception ex)
        {
            operException = ex;
        }
        isOperating = false;
    }

    async Task Upgrade()
    {
        string? version = PluginMarketService.GetLatestVersion(Plugin);
        string? currentVersion = PluginMarketService.GetInstalledVersion(Plugin.Id);
        if (version == null || currentVersion == null) return;
        isOperating = true;
        try
        {
            await PluginMarketService.InstallPlugin(Plugin, version);
            _ = NotificationService.Success(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 升级成功" });
            hasUpdate = PluginMarketService.HasUpdate(Plugin);
            await OnInstalled.InvokeAsync();
        }
        catch (Exception ex)
        {
            try
            {
                await PluginMarketService.InstallPlugin(Plugin, currentVersion);
                _ = NotificationService.Warning(new NotificationConfig { Message = $"插件 [{Plugin.Name}] 升级失败，已回退到 v{currentVersion}" });
            }
            catch { }
            operException = ex;
        }
        isOperating = false;
    }
}
