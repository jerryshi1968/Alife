@using Alife.Platform
@using Alife.Components.Services
@inject INotificationService NotificationService
@inject UpdateService UpdateService

<div style="padding: 24px; height: 100%; overflow-y: auto;">
    <Title Level="4" Style="margin-bottom: 24px;">系统配置</Title>

    <div style="margin-bottom: 24px;">
        <Text Strong Style="margin-bottom: 8px; display: block;">数据存储目录 (Storage)</Text>
        <div style="display: flex; gap: 8px; align-items: center;">
            <Input @bind-Value="storageFolderPath" Style="flex: 1;" ReadOnly/>
            <Button Icon="@IconType.Outline.FolderOpen" OnClick="@OnPickStorageFolderAsync"/>
        </div>
        <Text Type="@TextElementType.Secondary" Style="font-size: 12px; margin-top: 4px; display: block;">
            存放角色数据、对话记录等用户数据。重启后生效。
        </Text>
    </div>

    <div style="margin-bottom: 24px;">
        <Text Strong Style="margin-bottom: 8px; display: block;">运行时目录 (Runtime)</Text>
        <div style="display: flex; gap: 8px; align-items: center;">
            <Input @bind-Value="runtimeFolderPath" Style="flex: 1;" ReadOnly/>
            <Button Icon="@IconType.Outline.FolderOpen" OnClick="@OnPickRuntimeFolderAsync"/>
        </div>
        <Text Type="@TextElementType.Secondary" Style="font-size: 12px; margin-top: 4px; display: block;">
            存放浏览器数据、模型文件等运行时数据。重启后生效。
        </Text>
    </div>

    <Divider Style="margin: 16px 0;"/>

    <Title Level="5" Style="margin-bottom: 12px;">版本信息</Title>
    <Descriptions Column="1" Size="@DescriptionsSize.Small" Bordered>
        <DescriptionsItem Title="当前版本">
            <Text Code Style="font-size: 12px;">v@(_currentVersion)</Text>
        </DescriptionsItem>
        @if (_latestVersion != null)
        {
            <DescriptionsItem Title="最新版本">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <Text Code Style="font-size: 12px; color: #52c41a;">v@(_latestVersion)</Text>
                    @if (_isDownloading)
                    {
                        <Progress Percent="@_downloadProgress" Status="ProgressStatus.Active" Style="flex: 1;" />
                    }
                    else
                    {
                        <Button Type="@ButtonType.Primary" Size="@ButtonSize.Small" OnClick="StartUpdate">立即升级</Button>
                    }
                </div>
            </DescriptionsItem>
        }
    </Descriptions>
    <div style="margin-top: 8px;">
        @if (_isChecking)
        {
            <AntDesign.Text Type="@TextElementType.Secondary" Style="font-size: 12px;">正在检查更新...</AntDesign.Text>
        }
        else if (_latestVersion == null)
        {
            <Button Size="@ButtonSize.Small" OnClick="CheckForUpdate">检查更新</Button>
        }
    </div>

    <Divider Style="margin: 16px 0;"/>

    <Title Level="5" Style="margin-bottom: 12px;">路径一览</Title>
    <Descriptions Column="1" Size="@DescriptionsSize.Small" Bordered>
        <DescriptionsItem Title="StorageFolderPath">
            <Text Code Style="font-size: 12px;">@Platform.AlifePath.StorageFolderPath</Text>
        </DescriptionsItem>
        <DescriptionsItem Title="RuntimeFolderPath">
            <Text Code Style="font-size: 12px;">@Platform.AlifePath.RuntimeFolderPath</Text>
        </DescriptionsItem>
        <DescriptionsItem Title="TempFolderPath">
            <Text Code Style="font-size: 12px;">@Platform.AlifePath.TempFolderPath</Text>
        </DescriptionsItem>
    </Descriptions>
</div>

@code {
    string _currentVersion = null!;
    string? _latestVersion;
    UpdateInfo? _updateInfo;
    bool _isChecking;
    bool _isDownloading;
    int _downloadProgress;

    string storageFolderPath = Platform.AlifePath.StorageFolderPath;
    string runtimeFolderPath = Platform.AlifePath.RuntimeFolderPath;

    protected override void OnInitialized()
    {
        _currentVersion = UpdateService.GetCurrentVersion();
    }

    async Task CheckForUpdate()
    {
        _isChecking = true;
        await InvokeAsync(StateHasChanged);

        _updateInfo = await UpdateService.CheckForUpdateAsync();
        _latestVersion = _updateInfo?.Version;
        _isChecking = false;
        await InvokeAsync(StateHasChanged);

        if (_updateInfo == null)
            _ = NotificationService.Success(new NotificationConfig { Message = "当前已是最新版本~" });
    }

    async Task StartUpdate()
    {
        if (_updateInfo == null) return;

        _isDownloading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await UpdateService.ApplyUpdateAsync(_updateInfo, progress =>
            {
                _downloadProgress = progress;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            _isDownloading = false;
            _downloadProgress = 0;
            Console.WriteLine($"更新失败: {ex.Message}");
            await InvokeAsync(StateHasChanged);
        }
    }

    async Task OnPickStorageFolderAsync()
    {
        string? result = await Platform.AlifePlatform.PickFolderAsync();
        if (string.IsNullOrWhiteSpace(result) is false)
        {
            storageFolderPath = result;
            Platform.AlifePath.SetStorageFolderPath(storageFolderPath);
            _ = NotificationService.Success(new NotificationConfig { Message = "存储路径已保存！重启后生效喵~" });
        }
    }

    async Task OnPickRuntimeFolderAsync()
    {
        string? result = await Platform.AlifePlatform.PickFolderAsync();
        if (string.IsNullOrWhiteSpace(result) is false)
        {
            runtimeFolderPath = result;
            Platform.AlifePath.SetRuntimeFolderPath(runtimeFolderPath);
            _ = NotificationService.Success(new NotificationConfig { Message = "运行时目录已保存！重启后生效喵~" });
        }
    }
}
