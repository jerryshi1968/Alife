@using System.Reflection
@using Newtonsoft.Json
@inject ConfigurationSystem ConfigurationSystem

<div style="display: flex; flex-direction: column; gap: 24px;">
    <!-- 顶部元数据 -->
    <div style="background: #fafafa; padding: 24px; border-radius: 8px; border: 1px solid #f0f0f0;">
        <Flex Justify="FlexJustify.SpaceBetween" Align="FlexAlign.Start">
            <div>
                <Title Level="3" Style="margin: 0 0 4px 0;">@PluginAttr.Name</Title>
                <Text Type="@TextElementType.Secondary" Copyable>@PluginType.FullName</Text>
            </div>
            @if (PluginAttr.LaunchOrder != 0)
            {
                <Tag Color="@("blue")">启动顺序: @PluginAttr.LaunchOrder</Tag>
            }
        </Flex>
        
        <Paragraph Style="margin-top: 16px; color: rgba(0,0,0,0.65);">
            @PluginAttr.Description
        </Paragraph>

        @if (!string.IsNullOrEmpty(PluginAttr.Url))
        {
            <a href="@PluginAttr.Url" target="_blank"><Icon Type="link" /> 项目文档</a>
        }
    </div>

    <!-- 详情配置 -->
    <div style="padding-top: 16px;">
        @if (PluginAttr.ConfigurationUIType != null && typeof(IComponent).IsAssignableFrom(PluginAttr.ConfigurationUIType))
        {
            <DynamicComponent Type="PluginAttr.ConfigurationUIType" Parameters="GetParameters()" />
        }
        else
        {
            <TextArea AutoSize="true" MinRows="10" Style="font-family: monospace;" @bind-Value="jsonConfig" Disabled="@IsReadOnly" />
            <Button Type="@ButtonType.Primary" OnClick="SaveJsonConfig" Style="margin-top: 16px;" Block Disabled="@IsReadOnly">保存配置</Button>
        }
    </div>
</div>

@code {
    [Parameter] public Type PluginType { get; set; } = null!;
    [Parameter] public Character? Character { get; set; }
    [Parameter] public ChatActivity? ChatActivity { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }

    private PluginAttribute PluginAttr => PluginType.GetCustomAttribute<PluginAttribute>()!;
    private string jsonConfig = "{}";

    protected override void OnParametersSet()
    {
        if (PluginAttr.ConfigurationUIType == null)
        {
            jsonConfig = ConfigurationSystem.GetConfigurationJson(PluginType)?.ToString(Formatting.Indented) ?? "{}";
        }
    }

    private Dictionary<string, object> GetParameters()
    {
        var parameters = new Dictionary<string, object>
        {
            { "PluginType", PluginType }
        };

        if (PluginAttr.ConfigurationUIType != null)
        {
            if (Character != null && HasParameter(PluginAttr.ConfigurationUIType, "Character"))
            {
                parameters.Add("Character", Character);
            }

            if (ChatActivity != null && HasParameter(PluginAttr.ConfigurationUIType, "ChatActivity"))
            {
                parameters.Add("ChatActivity", ChatActivity);
            }

            if (HasParameter(PluginAttr.ConfigurationUIType, "IsReadOnly"))
            {
                parameters.Add("IsReadOnly", IsReadOnly);
            }
        }

        return parameters;
    }

    private bool HasParameter(Type type, string propertyName)
    {
        var property = type.GetProperty(propertyName, BindingFlags.Public | BindingFlags.Instance);
        return property != null && property.GetCustomAttribute<ParameterAttribute>() != null;
    }

    private void SaveJsonConfig()
    {
        try 
        {
            Type type = ConfigurationSystem.GetConfigurationType(PluginType)!;
            object configuration = JsonConvert.DeserializeObject(jsonConfig, type)!;
            ConfigurationSystem.SetConfiguration(PluginType, configuration);
            _ = NotificationService.Success(new NotificationConfig { Message = "配置已保存喵！" });
        }
        catch (Exception ex)
        {
            _ = NotificationService.Error(new NotificationConfig { Message = "保存失败：" + ex.Message });
        }
    }

    [Inject] private INotificationService NotificationService { get; set; } = null!;
}
